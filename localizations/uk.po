#: STRINGS.ITEMS.POWERS.PLAYER.steadfast.name
msgctxt "STRINGS.ITEMS.POWERS.PLAYER.steadfast.name"
msgid "Relentless"
msgstr "Невблаганний"

#: STRINGS.ITEMS.POWERS.PLAYER.sting_like_a_bee.desc
msgctxt "STRINGS.ITEMS.POWERS.PLAYER.sting_like_a_bee.desc"
