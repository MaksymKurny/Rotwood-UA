msgstr "Комбо важкий-легкий {name.concept_focus_hit}"

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_bullseye.desc
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_bullseye.desc"
msgid "Shoot a <#BLUE>Focus Heavy Attack</> that hits an <#RED>Enemy</> with the tip of the arrow as it hits the ground."
msgstr "Вистреліть <#BLUE>важкою фокусною атакою</>, щоб стріла влучила у <#RED>ворога</> кінчиком при ударі об землю."

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_bullseye.name
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_bullseye.name"
msgid "Bullseye!"
msgstr "В яблучко!"

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_heavy.desc
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_heavy.desc"
msgid "Shoot a <#BLUE>piercing</> <#RED>Heavy</> arrow with <#BLUE>Focus</> timing that hits <#RED>three or more Targets</>. Damage is NOT reduced per pierce.\n"
"{name.tutorial_complete_in_town}"
msgstr "Вистреліть <#BLUE>пронизливою</> <#RED>важкою</> стрілою з точним <#BLUE>фокусним часом</>, яка вразить <#RED>три або більше цілі</>. Шкода НЕ зменшується з кожним проникненням. \n"
"{name.tutorial_complete_in_town}"

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_heavy.name
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_heavy.name"
msgid "Piercing Heavy {name_multiple.concept_focus_hit}"
msgstr "Пронизливі важкі {name_multiple.concept_focus_hit}"

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_kills.desc
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_kills.desc"
msgid "Kill <#RED>Enemies</> using any <#BLUE>{name.weapon_bow} {name.concept_focus_hit}</>."
msgstr "Вбийте <#RED>ворога</> використовуючи <#BLUE>{name.concept_focus_hit} {4:{name.weapon_bow}}</>."

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_kills.name
