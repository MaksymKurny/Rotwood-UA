#: Convo.twn_shop_blacksmith.HUB0.corestone_crafting.giver.STATE_0.TALK_CRAFT_BOSS_WEAPON
msgctxt "Convo.twn_shop_blacksmith.HUB0.corestone_crafting.giver.STATE_0.TALK_CRAFT_BOSS_WEAPON"
msgid "agent:\n"
" Ah. I see ye've charged up that weapon with the <#KONJUR>Primeval Teffressence</> of a <#RED>{boss_name}</>.\n"
" [recipe:boss_weapon_recipe] I can finish it now, if ye've got the goods."
msgstr ""

#: Convo.twn_shop_blacksmith.HUB0.corestone_crafting.giver.STATE_0.TALK_CRAFT_CORESTONE_WEAPON
msgctxt "Convo.twn_shop_blacksmith.HUB0.corestone_crafting.giver.STATE_0.TALK_CRAFT_CORESTONE_WEAPON"
msgid "[recipe:corestone_weapon_recipe] Ye want me to make ye a <#RED>{name.weapon_crystal}</>?"
