#: Convo.dgn_seen_missing_friends_potion.HUB0.convo.giver.STATE_0.QUESTION_2B
msgctxt "Convo.dgn_seen_missing_friends_potion.HUB0.convo.giver.STATE_0.QUESTION_2B"
msgid "Sigh. Nevermind."
msgstr "Зітхнути. Нічого страшного."

#: Convo.dgn_seen_missing_friends_potion.HUB0.convo.giver.STATE_0.TALK2_CAN_BUY
