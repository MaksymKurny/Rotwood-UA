#: STRINGS.UI.MECHANIC_TUTORIALS.COOKING_UNLOCKED_P1.DESC
msgctxt "STRINGS.UI.MECHANIC_TUTORIALS.COOKING_UNLOCKED_P1.DESC"
msgid "Cook <#RED>meals</> at <#BLUE>{name.i_cooking_pot}</> with ingredients grown on your <#RED>{name.i_farm_plot}</>.\n\n"
"<#BLUE>{name.npc_cook}</> packs your <#BLUE>{name.i_lunchbox}</> with your prepared meals before you leave on a {name.run}."
msgstr "Готуйте <#RED>страви</> в <#BLUE>{2:{name.i_cooking_pot}}</> з інгредієнтів, вирощених на вашій <#RED>{2:{name.i_farm_plot}}</>.\n\n"
"<#BLUE>{Name.npc_cook}</> запакує приготовані страви в <#BLUE>{name.i_lunchbox}</> перед тим, як ви вирушаєте на {name.run}."

