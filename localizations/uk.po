#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman,steal_five_finger_brew].17
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman,steal_five_finger_brew].17"
msgid "!neutral\n"
" !angry\n"
