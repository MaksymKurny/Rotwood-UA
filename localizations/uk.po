msgstr "Коли ви <#RED>ідеально ухиляєтеся</>, отримуєте <#RED>100% шанс критичного удару на {seconds} секунд</>."

#: STRINGS.ITEMS.POWERS.PLAYER.sting_like_a_bee.name
msgctxt "STRINGS.ITEMS.POWERS.PLAYER.sting_like_a_bee.name"
msgid "Sting Like a Bee"
msgstr "Жалячи, як бджола"

