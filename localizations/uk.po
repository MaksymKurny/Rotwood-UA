#: Convo.twn_shop_blacksmith.HUB0.corestone_crafting.giver.STATE_0.TALK_REPAIR_CORESTONE_WEAPON_FREE
msgctxt "Convo.twn_shop_blacksmith.HUB0.corestone_crafting.giver.STATE_0.TALK_REPAIR_CORESTONE_WEAPON_FREE"
msgid "Repairs are on Lottie's tab 'til ye've charged it. Want me ta fix up yer <#RED>{equipped_weapon_name}</>?"
msgstr ""

#: Convo.twn_shop_blacksmith.HUB0.corestone_crafting.giver.STATE_0.TT_CANT_AFFORD
