msgstr "Праведна лють"

#: STRINGS.ITEMS.POWERS.PLAYER.revive_borrow_power.desc
msgctxt "STRINGS.ITEMS.POWERS.PLAYER.revive_borrow_power.desc"
msgid "When you <#RED>{name.concept_revive}</> an <#RED>{name.concept_ally}</> during combat, copy <#RED>{powers_borrowed} {name.concept_relic}</> from their loadout for the rest of the {name.combat_room}."
msgstr "Коли ви <#RED>{2:{name.concept_revive}}</> <#RED>{name.concept_ally}а</> під час бою, скопіюйте <#RED>{powers_borrowed} {2:{name.concept_relic}}</> з його спорядження до кінця {2:{name.combat_room}} галявини."

