msgctxt "STRINGS.ITEMS.POWERS.PLAYER.shrapnel.desc"
msgid "Anything you break in the environment shatters into <#RED>{projectiles} Projectiles</> that deal <#RED>{damage_mult}x your {name.concept_weapon_damage}</>."
msgstr "Усе, що ви розбиваєте в середовищі, розбивається на <#RED>{projectiles} снарядів</>, кожен завдає <#RED>{damage_mult}х {3:{name.concept_weapon_damage}}</>."

#: STRINGS.ITEMS.POWERS.PLAYER.shrapnel.name
msgctxt "STRINGS.ITEMS.POWERS.PLAYER.shrapnel.name"
