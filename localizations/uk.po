#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_airborne_heavy_to_light.desc
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_airborne_heavy_to_light.desc"
msgid "Knock a <#RED>{name.cabbageroll}</> out of the air with a <#BLUE>Focus Heavy Attack</>, then shoot it with a <#BLUE>Focus Light Attack</> while it is still <#RED>Airborne</>."
msgstr "Збийте <#RED>{Name.cabbageroll}</> в повітрі за допомогою <#BLUE>важкої фокусної атаки </>, а потім влучте у нього <#BLUE>легкою фокусною атакою</>, поки він ще <#RED>в повітрі</>."

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_airborne_heavy_to_light.name
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_airborne_heavy_to_light.name"
