msgstr "Туманна суміш"

#: STRINGS.ITEMS.POWERS.POTION_POWER.soothing_potion.desc
msgctxt "STRINGS.ITEMS.POWERS.POTION_POWER.soothing_potion.desc"
msgid "Immediately <#RED>Heal</> for <#RED>{heal} Health</>."
msgstr "Негайно <#RED>зцілює</> на <#RED>{heal} здоров'я</>."

#: STRINGS.ITEMS.POWERS.POTION_POWER.soothing_potion.name
msgctxt "STRINGS.ITEMS.POWERS.POTION_POWER.soothing_potion.name"
