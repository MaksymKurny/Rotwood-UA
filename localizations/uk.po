msgid "{name.weapon_bow} Focus Kills"
msgstr "Фокусовані вбивства {4:{name.weapon_bow}}"

#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_light.desc
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_light.desc"
msgid "Shoot a <#BLUE>piercing</> <#RED>Light</> arrow with <#BLUE>Focus</> timing that hits <#RED>two or more Targets</>. Damage is reduced per pierce.\n"
"{name.tutorial_complete_in_town}"
msgstr "Вистреліть <#BLUE>пронизливою</> <#RED>легкою</> стрілою з точним <#BLUE>фокусним часом</>, яка вразить <#RED>дві або більше цілі</>. Шкода зменшується з кожним проникненням.\n"
"{name.tutorial_complete_in_town}"

