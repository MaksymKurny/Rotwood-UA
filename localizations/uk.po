msgstr ""

#: Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_refiner].3
msgctxt "Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_refiner].3"
msgid "!neutral\n"
" !dubious\n"
" What're you looking at? Two can play the staring game, pal."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!happy\n"
" !gesture\n"
" Hop in the <#RED>{name.i_damselfly}</> when you're ready to Hunt."
msgstr "!happy\n"
" !gesture\n"
"Коли будете готові до полювання, сідайте в <#RED>{Name.i_damselfly}</>."

#: Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_scout].2"
msgid "!happy\n"
" !gesture\n"
" The <#RED>{name.i_damselfly}'s</> waiting when you're ready."
msgstr "!happy\n"
" !gesture\n"
"<#RED>{Name.i_damselfly}</> чекає, коли ви будете готові."

#: Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_scout].3
msgctxt "Quest.chat_fluff_fallback.QUIP.nothingtosay:[in_quest_chat_fluff_fallback,in_town,role_scout].3"
msgid "!happy\n"
" !gesture\n"
" The <#RED>{name.i_damselfly}'s</> ready when you are."
msgstr "!happy\n"
" !gesture\n"
