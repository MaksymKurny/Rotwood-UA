msgctxt "Convo.dgn_challenge_mt_magpie.HUB0.convo.giver.STATE_0.QUESTION_END3"
msgid "...You could use some entertainment. Gee, thanks."
msgstr "...тобі б не завадило розважитися. Ого, дякую."

