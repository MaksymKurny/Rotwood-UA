#: STRINGS.ITEMS.POWERS.SHIELD.shield_when_hurt.desc
msgctxt "STRINGS.ITEMS.POWERS.SHIELD.shield_when_hurt.desc"
msgid "When you take <#RED>{name.concept_damage}</>, gain <#BLUE>{shield} Shield Segment</>."
msgstr "Коли ви отримуєте <#RED>{name.concept_damage}</>, отримуйте <#BLUE>{shield} сегмент щита</>."

#: STRINGS.ITEMS.POWERS.SHIELD.shield_when_hurt.name
msgctxt "STRINGS.ITEMS.POWERS.SHIELD.shield_when_hurt.name"
msgid "Automated Defenses"
msgstr "Автоматизований захист"

#: STRINGS.ITEMS.POWERS.SKILL.bananapeel.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bananapeel.desc"
msgid "<#RED>Heals</> for <#RED>{heal} Health</> when eaten.\n\n"
"Leaves behind a <#RED>Banana Peel</> that inflicts <#RED>Knock Down</> on any target that steps on it.\n\n"
"Regain <#RED>1 Banana</> for every <#RED>{damage_til_new_banana} {name.concept_damage}</> dealt."
msgstr "<#RED>Зцілює</> на <#RED>{heal} здоров'я</> після вживання.\n\n"
"Залишає <#RED>бананову шкірку</>, яка може <#RED>збити з ніг</> будь-яку ціль, яка на неї наступить.\n\n"
"Відновить <#RED>1 банан</> після нанесення <#RED>{damage_til_new_banana} {2:{name.concept_damage}}</>."

#: STRINGS.ITEMS.POWERS.SKILL.bananapeel.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bananapeel.name"
msgid "Banana Peel"
msgstr "Бананова шкірка"

#: STRINGS.ITEMS.POWERS.SKILL.boss_eggzy.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_eggzy.desc"
msgid "Imbue your weapon with power, causing your next hit to explode.\n\n"
"Press <#RED>Skill</> during a <#RED>Heavy Attack</> to queue an explosion on Hit."
msgstr "Наділіть свою зброю силою, щоб наступний удар спричинив вибух.\n\n"
"Натисніть <#RED>навичку</> під час <#RED>важкої атаки</>, щоб активувати вибух при ударі."

#: STRINGS.ITEMS.POWERS.SKILL.boss_eggzy.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_eggzy.name"
msgid "Eggsplosion"
msgstr "Яйцевибух"

#: STRINGS.ITEMS.POWERS.SKILL.boss_grimhollow.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_grimhollow.desc"
msgid "Launch a continuous volley of <#RED>Mortar Shells</> at targets infront of you.\n\n"
"Take <#RED>Reduced Damage</> from the front while held."
msgstr "Випускає безперервний залп <#RED>мінометних снарядів</> по цілях перед вами.\n\n"
" Поки здібність утримується, ви отримуєте <#RED>зменшену шкоду</> від атак спереду."

#: STRINGS.ITEMS.POWERS.SKILL.boss_grimhollow.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_grimhollow.name"
msgid "Bastion Volley"
msgstr "Бастіонний обстріл"

#: STRINGS.ITEMS.POWERS.SKILL.boss_megatreemon.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_megatreemon.desc"
msgid "Summon <#RED>{name.megatreemon}'s Roots</>.\n\n"
"Press <#RED>Skill</> during a <#RED>Heavy Attack</> to queue a summon on Hit."
msgstr "Створіть ряд <#RED>коренів {2:{Name.megatreemon}}</>.\n\n"
"Натисніть <#RED>навичку</> під час <#RED>важкої атаки</>, щоб черговий раз створити при влучанні."

#: STRINGS.ITEMS.POWERS.SKILL.boss_megatreemon.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_megatreemon.name"
msgid "Mother of Methuselah"
msgstr "Мати Мафусаїла"

#: STRINGS.ITEMS.POWERS.SKILL.boss_owlitzer.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_owlitzer.desc"
msgid "Summon <#RED>{name.owlitzer}'s Wings</>."
msgstr "Викликає <#RED>крила {3:{name.owlitzer}}</>."

#: STRINGS.ITEMS.POWERS.SKILL.boss_owlitzer.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_owlitzer.name"
msgid "Keeper of the Moon"
msgstr "Хранитель місяця"

#: STRINGS.ITEMS.POWERS.SKILL.boss_sedament.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_sedament.desc"
msgid "You find yourself being followed by a <#RED>Crow</>.\n\n"
"Press <#RED>Skill</> to send your <#RED>Crow</> into a <#RED>Shiny Frenzy</>."
msgstr "За вами починає слідувати <#RED>ворона</>.\n\n"
"Натисніть <#RED>навичку</>, щоб відправити свою <#RED>ворону</> в <#RED>блискуче божевілля</>."

#: STRINGS.ITEMS.POWERS.SKILL.boss_sedament.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_sedament.name"
msgid "Holder of Shinies"
msgstr "Хранитель блискіток"

#: STRINGS.ITEMS.POWERS.SKILL.boss_thatcher.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_thatcher.desc"
msgid "While active, your <#RED>Attacks</> coats <#RED>Targets</> in <#RED>{name.concept_toxic}</>, which deals <#RED>{name.concept_damage}</> and maintains <#RED>Hit Streaks</>."
msgstr "Поки активовано, ваші <#RED>атаки</> покривають <#RED>цілі</> <#RED>{4:{name.concept_toxic}}</>, яка завдає <#RED>{name.concept_damage}</> та підтримує <#RED>серію влучань</>."

#: STRINGS.ITEMS.POWERS.SKILL.boss_thatcher.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.boss_thatcher.name"
msgid "Voice of the Myriad"
msgstr "Голос Міріади"

#: STRINGS.ITEMS.POWERS.SKILL.bow_fan.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_fan.desc"
msgid "Toss <#RED>{name.gnarlic} arrows</> in all directions.\n\n"
"<#RED>Kill</> {kills_to_refill} enemy to recharge, up to a maximum of <#RED>{max_stocks} Stocks</>."
msgstr "Киньте <#RED>стріли {2:{Name.gnarlic}}</> в усіх напрямках.\n\n"
"<#RED>Вбийте</> {kills_to_refill} ворогів, щоб перезарядити, максимум <#RED>{max_stocks} запаси</>."

#: STRINGS.ITEMS.POWERS.SKILL.bow_fan.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_fan.name"
msgid "Fan of {name_multiple.gnarlic}"
msgstr "Фанат {2:{name_multiple.gnarlic}}"

#: STRINGS.ITEMS.POWERS.SKILL.bow_hypershot.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_hypershot.desc"
msgid "Allow rapid-fire of <#RED>Light Attacks</> for the next <#RED>{seconds_active} seconds</>.\n\n"
"<z 0.8><i>Cooldown: <#RED>{cd}</> seconds</i></z>"
msgstr "Дозволяє швидкі постріли <#RED>легкою атакою</> протягом наступних <#RED>{seconds_active} секунд</>.\n\n"
"<z 0.8><i>Перезарядка: <#RED>{cd}</> секунд</i></z>"

#: STRINGS.ITEMS.POWERS.SKILL.bow_hypershot.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_hypershot.name"
msgid "Hypershot"
msgstr "Швидкостріл"

#: STRINGS.ITEMS.POWERS.SKILL.bow_melee.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_melee.desc"
msgid "Swing your <#RED>{name.weapon_bow}</> as a close-range attack."
msgstr "Розмахніть своїм <#RED>{4:{name.weapon_bow}}</> як ближньою атакою."

#: STRINGS.ITEMS.POWERS.SKILL.bow_melee.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_melee.name"
msgid "Thwack"
msgstr "Ляпас"

#: STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_acid.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_acid.desc"
msgid "Your next <#RED>Heavy Attack</> leaves an <#RED>{name.concept_toxic} Pool</> when hitting the ground."
msgstr "Ваша наступна <#RED>важка атака</> залишає <#RED>калюжу {3:{name.concept_toxic}}</> при влучанні в землю."

#: STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_acid.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_acid.name"
msgid "{name.concept_toxic} Dip"
msgstr "Занурення у {2:{name.concept_toxic}}"

#: STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_cold.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_cold.desc"
msgid "Your next <#RED>Heavy Attack</> leaves an <#RED>Ice Cloud</> when hitting the ground."
msgstr "Ваша наступна <#RED>важка атака</> залишає <#RED>крижану хмару</> при влучанні в землю."

#: STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_cold.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_cold.name"
msgid "Cold Plunge"
msgstr "Холодний стрибок"

#: STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_explode.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_explode.desc"
msgid "[TEMP] bow_primearrow_explode desc"
msgstr "[TEMP] bow_primearrow_explode desc"

#: STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_explode.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.bow_primearrow_explode.name"
msgid "[TEMP] bow_primearrow_explode"
msgstr "[TEMP] bow_primearrow_explode"

#: STRINGS.ITEMS.POWERS.SKILL.buffnextattack.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.buffnextattack.desc"
msgid "Pound your fists together to gain <#RED>+{percent_per_trigger}% Critical Chance</> until your next <#RED>Critical Hit</>."
msgstr "Стукніть кулаками, щоб отримати <#RED>+{percent_per_trigger}% шансу критичного удару</> до наступного <#RED>критичного удару</>."

#: STRINGS.ITEMS.POWERS.SKILL.buffnextattack.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.buffnextattack.name"
msgid "Fist Pound"
msgstr "Кулачний фунт"

#: STRINGS.ITEMS.POWERS.SKILL.cannon_aim.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_aim.desc"
msgid "Hold to charge a <#RED>Big Blast</> that deals major <#RED>Damage</>. Press <#RED>Skill</> again upon landing to chain multiple shots together."
msgstr "Утримуйте, щоб зарядити <#RED>потужний удар</>, який завдає великої <#RED>шкоди</>. Натисніть <#RED>навичку</> ще раз при приземленні, щоб з'єднати кілька пострілів разом."

#: STRINGS.ITEMS.POWERS.SKILL.cannon_aim.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_aim.name"
msgid "Big Blast"
msgstr "Потужний удар"

#: STRINGS.ITEMS.POWERS.SKILL.cannon_butt.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_butt.desc"
msgid "Hit an enemy with the butt of your <#RED>{name.weapon_cannon}</>.\n\n"
"On hit, gain <#RED>1 {name.cannon_ammo}</>."
msgstr "Вдарте ворога прикладом вашої <#RED>{3:{name.weapon_cannon}}</>.\n\n"
"Після удару <#RED>отримайте 1 {name.cannon_ammo}</>."

#: STRINGS.ITEMS.POWERS.SKILL.cannon_butt.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_butt.name"
msgid "Battering Ram"
msgstr "Штурмовий таран"

#: STRINGS.ITEMS.POWERS.SKILL.cannon_proximitymine.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_proximitymine.desc"
msgid "Plant one of your <#RED>{name_multiple.cannon_ammo}</> as a <#RED>Mine</> which blows up near enemies. Perform a <#RED>Shockwave</> to explode all <#RED>Mines</>."
msgstr "Встановіть одну <#RED>міну</>, з ваших <#RED>{2:{name_multiple.cannon_ammo}}</> яка вибухає біля ворогів. Застосуйте <#RED>ударну хвилю</>, щоб підірвати всі <#RED>міни</>."

#: STRINGS.ITEMS.POWERS.SKILL.cannon_proximitymine.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_proximitymine.name"
msgid "Proximity Mines"
msgstr "Контактні міни"

#: STRINGS.ITEMS.POWERS.SKILL.cannon_singlereload.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_singlereload.desc"
msgid "Reload <#RED>1 {name.cannon_ammo}</>."
msgstr "Зарядить <#RED>1 {name.cannon_ammo}</>."

#: STRINGS.ITEMS.POWERS.SKILL.cannon_singlereload.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.cannon_singlereload.name"
msgid "Reload One"
msgstr "Перезаряджання"

#: STRINGS.ITEMS.POWERS.SKILL.hammer_explodingheavy.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_explodingheavy.desc"
msgid "Overcharge your <#RED>{name.weapon_hammer}</> with energy which explodes the next time your <#RED>Heavy Attack</> hits something."
msgstr "Перевантажте свій <#RED>{name.weapon_hammer}</> енергією, яка вибухне, коли ваша <#RED>важка атака</> влучить у щось."

#: STRINGS.ITEMS.POWERS.SKILL.hammer_explodingheavy.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_explodingheavy.name"
msgid "Unstable Equilibrium"
msgstr "Нестабільна рівновага"

#: STRINGS.ITEMS.POWERS.SKILL.hammer_reflectinglights.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_reflectinglights.desc"
msgid "<#RED>Light Attacks</> during <#RED>Hypershot</> deal Bonus <#RED>Damage</>."
msgstr "<#RED>Легкі атаки</> в режимі <#RED>Швидкострілу</> наносять бонусну <#RED>шкоду</>."

#: STRINGS.ITEMS.POWERS.SKILL.hammer_reflectinglights.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_reflectinglights.name"
msgid "[TEMP] hammer_reflectinglights"
msgstr "[TEMP] hammer_reflectinglights"

#: STRINGS.ITEMS.POWERS.SKILL.hammer_reflectinglights.variables.hypershot_damage_bonus
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_reflectinglights.variables.hypershot_damage_bonus"
msgid "Damage Bonus"
msgstr "Бонусна шкода"

#: STRINGS.ITEMS.POWERS.SKILL.hammer_thump.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_thump.desc"
msgid "Pound the head of your <#RED>{name.weapon_hammer}</> into the ground, causing <#RED>Knockback</> to any nearby <#RED>Enemies</>.\n\n"
"Hold <#RED>Skill</> to charge."
msgstr "Вдарте <#RED>{4:{name.weapon_hammer}}</> по землі, спричиняючи <#RED>Відкидання</> для будь-яких <#RED>ворогів</> поблизу.\n\n"
"Утримуйте <#RED>{2:{name.concept_skill}}</>, щоб зарядити."

#: STRINGS.ITEMS.POWERS.SKILL.hammer_thump.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_thump.name"
msgid "Order in the Court"
msgstr "Порядок у суді"

#: STRINGS.ITEMS.POWERS.SKILL.hammer_totem.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_totem.desc"
msgid "Sacrifice <#RED>{healthtocreate} Health</> to summon a <#RED>Hazard Idol</>.\n\n"
"<#RED>Everything</> in a large radius of the <#RED>Idol</> deals <#RED>+{bonusdamagepercent}% {name.concept_damage}</>.\n\n"
"The Idol <#RED>Heals</> its destroyer for <#RED>{healthtocreate} Health</>."
msgstr "Пожертвуйте <#RED>{healthtocreate} здоров'я</>, щоб викликати <#RED>ідола небезпеки</>..\n\n"
"<#RED>Все</> у великому радіусі <#RED>ідола</> завдає <#RED>+{bonusdamagepercent}% {2:{name.concept_damage}}</>.\n\n"
"Ідол <#RED>лікує</> того хто зруйнував його на <#RED>{healthtocreate} здоров'я</>."

#: STRINGS.ITEMS.POWERS.SKILL.hammer_totem.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.hammer_totem.name"
msgid "Hazard Idol"
msgstr "Ідол небезпеки"

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_bonejaw.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_bonejaw.desc"
msgid "<#RED>Hold</> to stampede, then release to do a rising <#RED>Headbutt</>."
msgstr "<#RED>Утримуйте</> для шаленого ривка, а потім відпустіть, щоб виконати підкичаючий <#RED>удар головою</>."

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_bonejaw.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_bonejaw.name"
msgid "{name.bonejaw}'s Charge"
msgstr "Ривок {2:{Name.bonejaw}}"

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_crystroll.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_crystroll.desc"
msgid "Shoot an <#RED>Ice Chunk</>, or <#RED>Hold</> to shoot all stocked <#RED>Ice Chunks</>.\n\n"
"Regain <#RED>1 Stock</> every <#RED>{hitstreak} Hit Streak</>, up to a maximum of <#RED>3 Stocks</>."
msgstr "Стріляйте <#RED>крихтою льоду</> або <#RED>утримуйте</>, щоб вистрілити усіма наявними <#RED>крихтами льоду</>.\n\n"
"Відновлюйте <#RED>1 запас</> кожну <#RED>{hitstreak} серію влучань</>, максимум <#RED>3 запаси</>."

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_crystroll.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_crystroll.name"
msgid "{name.crystroll}'s Ice Puke"
msgstr "Крижаний подих {Name.crystroll}а"

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_embison.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_embison.desc"
msgid "<#RED>Hold</> to charge, then release to do an <#RED>Invincible</> turn into a punch, releasing all stored energy."
msgstr "<#RED>Утримуйте</>, щоб зарядити, потім відпустіть, щоб виконати <#RED>невразливий</> поворотний удар, випускаючи всю накопичену енергію."

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_embison.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_embison.name"
msgid "{name.embison}'s Turn Around Punch"
msgstr "Удар з поворотом {2:{Name.embison}}"

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_floracrane.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_floracrane.desc"
msgid "Leap into the air and divebomb the ground in front of you.\n\n"
"Hold to charge, turning your dive into a <#BLUE>Focus Hit</>."
msgstr "Злетіть у повітря і вдарте у землю перед собою.\n\n"
"Утримуйте, щоб зарядити, перетворюючи ваш стрибок на <#BLUE>фокусний удар</>."

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_floracrane.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_floracrane.name"
msgid "{name.floracrane}'s Divebeak"
msgstr "Дзьоб {2:{Name.floracrane}}"

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_gourdo.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_gourdo.desc"
msgid "Channel your inner seedling, restoring <#RED>{heal} Health</> to yourself and all <#RED>Allies</> within a medium radius.\n\n"
"Regain <#RED>1 Stock</> for every <#RED>{damage_til_new_stock} {name.concept_damage}</> dealt, up to a maximum of <#RED>3 Stocks</>."
msgstr "Використовуйте свій внутрішній саджанець, відновлюючи <#RED>{heal} здоров'я</> собі та всім <#RED>союзникам</> в середньому радіусі.\n\n"
"Відновіть <#RED>1 заряд</> після нанесення <#RED>{damage_til_new_stock} {2:{name.concept_damage}}</>, максимум <#RED>3 заряди</>."

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_gourdo.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_gourdo.name"
msgid "{name.gourdo}'s Community Garden"
msgstr "Громадський сад {Name.gourdo}"

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_groak.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_groak.desc"
msgid "<#RED>Vacuum</> all <#RED>Enemies</> standing in front of you in towards yourself, dealing many tiny hits."
msgstr "<#RED>Притягніть</> всіх <#RED>ворогів</>, які стоять перед вами, до себе, завдаючи багато дрібних ударів."

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_groak.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_groak.name"
msgid "Grody {name.groak} Gulp"
msgstr "Гроді {Name.groak} Глуп"

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_yammo.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_yammo.desc"
msgid "Hold to charge a <#BLUE>Focus Attack</>. Any <#RED>Damage</> received while charging is added to the total <#RED>Damage</> of the attack.\n\n"
"On hit, <#RED>Heal</> back all absorbed <#RED>Damage</>."
msgstr "Утримуйте, щоб зарядити <#BLUE>фокусну атаку</>. Будь-яка <#RED>шкода</>, отримана під час заряджання, додається до загальної <#RED>шкоди</> від атаки.\n\n"
"При влучанні <#RED>лікуєтеся</> на всю поглинену <#RED>шкоду</>."

#: STRINGS.ITEMS.POWERS.SKILL.miniboss_yammo.name
msgctxt "STRINGS.ITEMS.POWERS.SKILL.miniboss_yammo.name"
msgid "Big {name.yammo} Slammo"
