#: Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_2D
msgctxt "Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_2D"
msgid "Okay, I think I get the point."
msgstr "Гаразд, думаю, я зрозумів суть."

#: Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_END
msgctxt "Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_END"
msgid "Bye! Thanks for explaining the <i>main thrust</i> of {name_multiple.weapon_polearm}!"
msgstr "Бувай! Дякую за пояснення <i>основного принципу</i> {2:{name_multiple.weapon_polearm}}!"

