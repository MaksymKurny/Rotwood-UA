#: Quest.dgn_shop_potion.OPT_ASK_CURSE
msgctxt "Quest.dgn_shop_potion.OPT_ASK_CURSE"
msgid "<#RED>[TEMP]</> Your free sample smells weird..."
msgstr "<#RED>[TEMP]</> Ваш безплатний зразок дивно пахне..."

#: Quest.dgn_shop_potion.OPT_CONFIRM
msgctxt "Quest.dgn_shop_potion.OPT_CONFIRM"
msgid "<#RED>[<p img='images/hud_images/hud_konjur_drops_currency.tex'> {konjur_cost} {name.konjur}]</> Take my {name.konjur}!\n"
"<i><#RED><z 0.7>(Refill All Potion Charges)</></i></z>"
msgstr "<#RED>[<p img='images/hud_images/hud_konjur_drops_currency.tex'> {konjur_cost} {2:{name.konjur}}]</> Візьми мій {name.konjur}!\n"
"<i><#RED><z 0.7>(Поновити всі заряди зілля)</></i></z>"

#: Quest.dgn_shop_potion.OPT_REMOVE_CURSE
msgctxt "Quest.dgn_shop_potion.OPT_REMOVE_CURSE"
msgid "<#RED>[<p img='images/hud_images/hud_konjur_drops_currency.tex'> {konjur_cost} {name.konjur}]</><#RED>[TEMP]</> Sure, yes please! <i><#RED><z 0.7>(Clean \"Free\" Sample)</></i></z>"
msgstr "<#RED>[<p img='images/hud_images/hud_konjur_drops_currency.tex'> {konjur_cost} {2:{name.konjur}}]</><#RED>[TEMP]</> Звичайно, так, будь ласка! <i><#RED><z 0.7>(Чистий «безплатний» зразок)</></i></z>"

#: Quest.dgn_shop_potion.OPT_REMOVE_CURSE_CANCEL
msgctxt "Quest.dgn_shop_potion.OPT_REMOVE_CURSE_CANCEL"
msgid "<#RED>[TEMP]</> I'll pass for now..."
msgstr "<#RED>[TEMP]</> Я поки що пас..."

#: Quest.dgn_shop_potion.OPT_TALK_CURSE
msgctxt "Quest.dgn_shop_potion.OPT_TALK_CURSE"
msgid "agent:\n"
" !shrug\n"
" <#RED>[TEMP]</> Ssseems fine. I can fix it for a little {name.konjur} if you want..."
msgstr "agent:\n"
" !shrug\n"
" <#RED>[TEMP]</> Сссхоже все добре. Я можу підправити його за трохи {2:{name.konjur}}, якщо хочете..."

#: Quest.dgn_shop_potion.TALK_DONE_GAME
msgctxt "Quest.dgn_shop_potion.TALK_DONE_GAME"
