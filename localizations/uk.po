msgstr "Збільшують на <#RED>+{speed}% {name.concept_runspeed}</>."

#: STRINGS.ITEMS.POWERS.PLAYER.running_shoes.name
msgctxt "STRINGS.ITEMS.POWERS.PLAYER.running_shoes.name"
