msgstr "Як зробити {name_multiple.concept_focus_hit}?"

#: Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_2B_ALT
msgctxt "Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_2B_ALT"
msgid "I immediately forgot everything you said about {name_multiple.concept_focus_hit}."
msgstr "Я одразу забув усе, що ти сказав про {name_multiple.concept_focus_hit}."

#: Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_2C
msgctxt "Convo.twn_polearm_explainer.HUB0.convo.giver.STATE_0.QUESTION_2C"
