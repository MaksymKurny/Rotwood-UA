#: Quest.twn_repeatable_tutorials_dojo.TALK_SELECT_DEFENSE
msgctxt "Quest.twn_repeatable_tutorials_dojo.TALK_SELECT_DEFENSE"
msgid "agent:\n"
" !gruffnod\n"
" Defense. {name.dojo_cough} 'Course."
