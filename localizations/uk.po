msgstr "Зброя"

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.WEAPONS_BTN_REVIEW
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.WEAPONS_BTN_REVIEW"
msgid "Weapons <#RED><z 0.7>(Review)</z></>"
msgstr "Зброя <#RED><z 0.7>(Відгук)</z></>"

#: Quest.twn_revive_cost_explainer.QUIP.chitchat:[in_quest_twn_revive_cost_explainer,in_town,multiplayer,reviver_health_loss,role_dojo].1
msgctxt "Quest.twn_revive_cost_explainer.QUIP.chitchat:[in_quest_twn_revive_cost_explainer,in_town,multiplayer,reviver_health_loss,role_dojo].1"
msgid "agent:\n"
" !neutral\n"
" !cough\n"
" {name.dojo_cough} Kid-- er, Hunter!\n"
" player:\n"
" What is it, {name.npc_dojo_master}?\n"
" agent:\n"
" !neutral\n"
" !gesture\n"
" I wanted to warn you-- all that {name.c_konjur} in those <#RED>Frenzied</> areas is gonna start messing with your ability to <#RED>{name.concept_revive}</> your fellow {name_multiple.hunter}.\n"
" !point\n"
" Every time you <#RED>{name.concept_revive}</> someone, a bit of your <#RED>{name.concept_health}</> will be leeched away.\n"
" !disagree\n"
" I didn't think I'd see it again. It hasn't been like this since... since <#RED><i>back then</></>.\n"
" player:\n"
" Okay, I'll be careful.\n"
" agent:\n"
" !very_sick\n"
" {name.dojo_cough} Watch each other's backs out there, y'hear me?"
msgstr "agent:\n"
" !neutral\n"
" !cough\n"
" {Name.dojo_cough} Друже... тобто, Мисливцю!\n"
" player:\n"
" Що таке, {Name.npc_dojo_master}?\n"
" agent:\n"
" !neutral\n"
" !gesture\n"
" Я хотів попередити вас... у тих <#RED>божевільних</> місцинах надлишок {2:{name.c_konjur}} почне заважати вашій здатності <#RED>{name.concept_revive}</> своїх {3:{name_multiple.hunter}}.\n"
" !point\n"
" Кожного разу, коли ви когось <#RED>{2:{name.concept_revive}}</>, частинка вашого <#RED>{name.concept_health}</> буде висмоктана.\n"
" !disagree\n"
" Не думав, що знову це побачу. Такого не було ще з… з <#RED><i>тих часів</></>.\n"
" player:\n"
" Добре, я буду обережним.\n"
" agent:\n"
" !very_sick\n"
" {name.dojo_cough} Бережіть одне одного там, гаразд?"

#: Quest.twn_shotput_explainer.QUIP.chitchat:[in_quest_twn_shotput_explainer,in_town,pf_unlocked_masteries,role_dojo,weapon_type_shotput].1
msgctxt "Quest.twn_shotput_explainer.QUIP.chitchat:[in_quest_twn_shotput_explainer,in_town,pf_unlocked_masteries,role_dojo,weapon_type_shotput].1"
msgid "agent:\n"
" !neutral\n"
" !greet\n"
" 'Ey, kid.\n"
" !gesture\n"
" Say, that's a mighty fine <#RED>Weapon</> you got there."
msgstr "agent:\n"
"!neutral\n"
"!greet\n"
"Привіт, друже.\n"
"!gesture\n"
"Слухайте, у вас дуже гарна <#RED>зброя</>."

#: Quest.twn_toot_and_flitt_origin_scout.QUIP.chitchat:[chitchat,has_killed_megatreemon,has_killed_owlitzer,in_quest_twn_toot_and_flitt_origin_scout,in_town,role_scout].1
msgctxt "Quest.twn_toot_and_flitt_origin_scout.QUIP.chitchat:[chitchat,has_killed_megatreemon,has_killed_owlitzer,in_quest_twn_toot_and_flitt_origin_scout,in_town,role_scout].1"
msgid "!neutral\n"
" !angry\n"
" <z 0.7><i>Darn it, <#BLUE>{name.npc_dojo_master}</>... I can only replace your inhaler refills if you tell me you're out.</></>\n"
" !happy\n"
" !dubious\n"
" Oh, hey Hunter. Sorry, just working on camp provisioning right now."
msgstr ""

#: Quest.twn_weapon_weight_blacksmith.QUIP.chitchat:[in_quest_twn_weapon_weight_blacksmith,in_town,qc_dgn_firstmeeting_blacksmith,role_blacksmith].1
msgctxt "Quest.twn_weapon_weight_blacksmith.QUIP.chitchat:[in_quest_twn_weapon_weight_blacksmith,in_town,qc_dgn_firstmeeting_blacksmith,role_blacksmith].1"
msgid "agent:\n"
" !neutral\n"
" !dubious\n"
" ...Hunter."
msgstr "agent:\n"
" !neutral\n"
" !dubious\n"
" ...Мисливець."

#: Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].1
msgctxt "Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].1"
msgid "!neutral\n"
" !shrug\n"
" <i>Am</> I here? Or have I just <i>dreamt</> of being here? He. He. He.\n"
" !gesture\n"
" <i>*(She holds out her hand. It is emptiness)*</>"
msgstr "!neutral\n"
" !shrug\n"
" Я <i>тут?</> Чи це мені просто <i>приснилося</>, що я тут? Хе. Хе. Хе.\n"
" !gesture\n"
" <i>*(Вона простягає руку. Там - порожньо)*</>"

#: Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].2
msgctxt "Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].2"
msgid "!neutral\n"
" !think\n"
" Am I a thread sewn, or a thread yet dangling?\n"
" !dubious\n"
" Did <i>you</> sew, O Thimble-less One? He. He. He."
msgstr "!neutral\n"
" !think\n"
" Я - нитка, що вже пришита, чи нитка, що ще звисає?\n"
" !dubious\n"
" Це <i>ви</> шили, хто не має наперстка?? Хе. Хе. Хе."

#: Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].3
msgctxt "Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].3"
msgid "!neutral\n"
" !think\n"
" Is Time with no sequence still Time?\n"
" !eyeroll\n"
" Formless puzzle pieces dumped across the sky.\n"
" !point\n"
" Start with the corners, or they'll start with <i>you.</>"
msgstr "!neutral\n"
" !think\n"
" Чи є Час без послідовності все ще Часом?\n"
" !eyeroll\n"
" Безформні шматочки пазла, розсипані по небу.\n"
" !point\n"
" Почніть із кутів, інакше вони почнуть з <i>вас.</>"

#: Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].4
msgctxt "Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].4"
msgid "!happy\n"
" !gesture\n"
" <i>*(She flips a coin)*</>\n"
" <i>*(The coin shrinks and disappears)*</>\n"
" Don't be afraid. This is good luck."
msgstr "!happy\n"
" !gesture\n"
" <i>*(Вона підкидає монету)*</>\n"
" <i>*(Монета зменшується і зникає)*</>\n"
" Не бійтеся. Це на щастя."

#: Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].5
msgctxt "Quest.twn_welcome_to_town_refiner.QUIP.unrescued_nonsense:[in_quest_twn_welcome_to_town_refiner,role_refiner].5"
msgid "!neutral\n"
" !agree\n"
" Sap and ozone.\n"
" Sap and ozone.\n"
" Sap and ozone.\n"
" I'm not broken. Free.\n"
" Skibbety-bap."
msgstr "!neutral\n"
" !agree\n"
" Смола і озон.\n"
" Смола і озон.\n"
" Смола і озон.\n"
" Я не зламана. Вільна.\n"
" Скіббеті-бап."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]confused.1"
msgid "Oh, do you think you need more Heartstones? Sure, I suppose..."
msgstr "О, думаєте, вам потрібно більше кам'яних сердець? Гаразд, мабуть..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]confused.2"
msgid "You aren't scared, are you?"
msgstr "Ви ж не боїтеся, правда?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]confused.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]confused.3"
msgid "He's not making it easy on you, is he? Is it 'he' or 'they'?"
msgstr "Він не полегшує вам завдання, чи не так? Це 'він' чи 'вони'?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]motivational.1"
msgid "It's okay, Hunter. It's good to know when to step back and regroup."
msgstr "Усе гаразд, Мисливцю. Добре знати, коли варто відступити й перегрупуватися."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]motivational.2"
msgid "It's a tough fight so I get it. We'll come back stronger!"
msgstr "Бій непростий, тож я розумію. Ми повернемося сильнішими!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]motivational.3"
msgid "It's okay. We've got time, Hunter. Though not much..."
msgstr "Усе гаразд. У нас ще є час, Мисливцю. Хоч і небагато..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]sad.1"
msgid "I... I need a minute too, Hunter."
msgstr "Мені... мені теж потрібна хвилина, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]sad.2"
msgid "I can't stand seeing him like that either..."
msgstr "Я теж не можу дивитися на нього таким..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]sad.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]sad.3"
msgid "Let's pull ourselves together back at camp, hm? (sniffle)"
msgstr "Зберімось з думками в таборі, га? (шморгає)"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]skeptical.1"
msgid "Okay, recharge at camp but we have to stop him and the Second Eruption."
msgstr "Добре, відновіться в таборі, але нам потрібно зупинити його і Друге Виверження."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]skeptical.2"
msgid "I think you could've clinched it, Hunter, but... okay. Let's go."
msgstr "Думаю, ви могли б дотиснути, Мисливцю, але... гаразд. Ходімо."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,in_end_boss,tefframech]skeptical.3"
msgid "We're leaving? Um, okay. We'll regroup, but so will he--er, they."
msgstr "Ми йдемо? Гаразд. Ми перегрупуємося, але він... вони теж."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]confused.1"
msgid "Are you feeling okay? You weren't mowing enemies down like usual..."
msgstr "Ви добре почуваєтесь? Ви не косили ворогів, як зазвичай..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]confused.2"
msgid "Have Hamish do an equipment check. Something felt off, there."
msgstr "Нехай Гаміш перевірить спорядження. Там щось було не так."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]confused.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]confused.3"
msgid "You felt that too, Hunter? That things weren't going quite right?"
msgstr "Ви теж це відчули, Мисливцю? Наче щось пішло не так?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]motivational.1"
msgid "No problem, Hunter. I'll book it back to Camp."
msgstr "Без проблем, Мисливцю. Я миттю повернуся до табору."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]motivational.2"
msgid "I'm sure abandoning this run is all part of your master plan, huh?"
msgstr "Я впевнений, що покинути цей забіг - частина вашого геніального плану, так?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]motivational.3"
msgid "A tactical retreat! Grandpa never saw THIS coming! (Neither did I...)"
msgstr "Тактичний відступ! Дідусь такого ТОЧНО не очікував! (Як і я...)"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.1"
msgid "Oh, you want to leave now? Like, now-now? Um, okay, Hunter."
msgstr "О, ви хочете піти просто зараз? Тобто прямо зараз-зараз? Ем, гаразд, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.2"
msgid "Leaving mid-saving-the-world? I guess we can come back."
msgstr "Йти посеред порятунку світу? Гадаю, ми можемо повернутися пізніше."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.3"
msgid "The Second Eruption feels imminent, but okay, let's circle back."
msgstr "Друге Виверження вже майже почалося, але гаразд, повернімося."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.1"
msgid "Did you forget something at camp?"
msgstr "Ви щось забули в таборі?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.2"
msgid "Did you leave the iron on? \n"
"...Do we even have an iron?"
msgstr "Ви залишили праску увімкненою?\n"
"...У нас хоч праска є?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.3"
msgid "Lost your nerve?"
msgstr "Здали нерви?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]confused.4"
msgid "Let's get you back to camp."
msgstr "Повернімо вас до табору."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.1"
msgid "Alright, hold tight Hunter."
msgstr "Добре, тримайся, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.2"
msgid "Sending down the rope now!"
msgstr "Відправляю мотузку прямо зараз!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.3"
msgid "Alright, Hunter. Let's head home."
msgstr "Гаразд, Мисливцю. Ходімо додому."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.4"
msgid "Don't feel bad about running away.\n"
"I do it all the time!"
msgstr "Не сумуйте про те, що втекли.\n"
"Я роблю це весь час!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.5
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.5"
msgid "You tucked tail very bravely, Hunter."
msgstr "Ви дуже хоробро підібрали хвоста, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.6
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.6"
msgid "Next stop--home!"
msgstr "Наступна зупинка... дім!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.7
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]motivational.7"
msgid "We can try again later."
msgstr "Ми спробуємо ще раз пізніше."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]skeptical.1"
msgid "Got cold feet, huh?"
msgstr "Злякався, так?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]skeptical.2"
msgid "Sometimes you just gotta cut your losses."
msgstr "Іноді просто треба визнати свою поразку."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[abandoned]skeptical.3"
msgid "It's good to have a healthy fear of {name_multiple.rot}."
msgstr "Добре мати здоровий страх, якщо поруч {name_multiple.rot}."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[after_mid_boss,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[after_mid_boss,lost]motivational.1"
msgid "Don't be discouraged. You made it halfway through the Hunt!"
msgstr "Не падайте духом. Ви пройшли половину полювання!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[any_frenzy,got_loot_volcanokey1,won]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[any_frenzy,got_loot_volcanokey1,won]motivational.1"
msgid "Lab Key Fragment number one, in the bag--literally!"
msgstr "Фрагмент ключа від лабораторії номер один, у сумці... буквально!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[any_frenzy,got_loot_volcanokey2,won]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[any_frenzy,got_loot_volcanokey2,won]motivational.1"
msgid "That's two Key Fragments down. Just one left. We can do this."
msgstr "Уже два фрагменти ключа. Залишився ще один. Ми впораємося."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[any_frenzy,got_loot_volcanokey3,won]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[any_frenzy,got_loot_volcanokey3,won]motivational.1"
msgid "That's all three Key Fragments! Let's regroup at Camp before facing Grandpa..."
msgstr "Усі три фрагменти ключа! Перегрупуймось в таборі перед тим, як зустрітися з Дідусем..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]confused.1"
msgid "What a sneaky rascal!"
msgstr "Яка підступна негідниця!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]confused.2"
msgid "<i>Two</> of them? Well that hardly seems fair."
msgstr "Їх <i>двоє</>? Ну, це вже майже нечесно."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]confused.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]confused.3"
msgid "Was I seeing double?"
msgstr "В мене двоїться?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]frustrated.1"
msgid "That gal may look fox-like, but she's no cousin of mine."
msgstr "Це дівча може виглядати як лисиця, але вона не моя кузина."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]nervous.1"
msgid "Ah. They say a hunted animal is most dangerous when it's cornered."
msgstr "Ага. Кажуть, що здобич найбільш небезпечна, коли її заганяють у кут."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]nervous.2"
msgid "Woah, she went feral at the end there!"
msgstr "Ого, вона здичавіла в кінці!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]sad.1"
msgid "Well jeez, she didn't have to laugh so hard at us."
msgstr "Ну от, вона не мусила так сильно сміятися над нами."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.1"
msgid "Can't quite put my claw on it, but...\n"
"Something seems a little off about one of those copies."
msgstr "Можу не влучити кігтем, але...\n"
"Здається, що з однією з тих копій щось не так."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.2"
msgid "If you let her rage long enough, she's bound to tucker herself out."
msgstr "Якщо ви дозволите їй достатньо довго лютувати, вона мусить втомитися."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.3"
msgid "She's too saturated with {name.konjur} to fully conceal herself.\n"
"Keep an eye on the veins of those rocks."
msgstr "У неї забагато {3:{name.konjur}}, щоб повністю приховати себе.\n"
"Слідкуйте за прожилками тих скель."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bandicoot,in_end_boss,lost]skeptical.4"
msgid "Did you see that? She was taunting you!\n"
"Almost like she <i>wanted</i> you to attack her."
msgstr "Ви бачили це? Вона насміхалася над вами!\n"
"Здається, вона <i>хотіла</i>, щоб ви напали на неї."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]confused.1"
msgid "Looks like it's not going to roll over that easily..."
msgstr "Здається, так просто він не здасться..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]motivational.1"
msgid "Don't lose hope, Hunter. We'll get it next time!"
msgstr "Не втрачайте надію, Мисливцю. Наступного разу ми його здолаємо!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]motivational.2"
msgid "Hang in there, Hunter! I've got your back!"
msgstr "Тримайтеся, Мисливцю! Я підстрахую вас!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]motivational.3"
msgid "Don't worry Hunter, you'll beat the snot out of that {name.blarmadillo_miniboss} next time!"
msgstr "Не хвилюйтеся, Мисливцю, наступного разу ви виб'єте всі соплі з того {Name.blarmadillo_miniboss}!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]nervous.1"
msgid "Oof. That {name.blarmadillo_miniboss} is nothing to sneeze at."
msgstr "Уф. Той {Name.blarmadillo_miniboss} – це не жарти."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]nervous.2"
msgid "I thought you were really on a roll there..."
msgstr "Я думав, ви вже були на справжньому підйомі..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[blarmadillo,in_bossbattle,lost]skeptical.1"
msgid "I'm afraid this Hunt's been trunkated."
msgstr "Боюся, це полювання завершилося передчасно."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]frustrated.1"
msgid "There's no getting through to this bonehead!"
msgstr "До цього кісткоголового не достукатися!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]motivational.1"
msgid "Wait for him to tire himself out, that's your chance to strike!"
msgstr "Чекайте, поки він втомиться – тоді й завдавайте удар!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]motivational.2"
msgid "You'll get him next time, I know it!"
msgstr "Наступного разу ви з ним точно впораєтесь, я впевнений!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]nervous.1"
msgid "Yikes! That looked like it hurt..."
msgstr "Ой! Це виглядало боляче..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]sad.1"
msgid "Hang in there, Hunter!"
msgstr "Тримайтеся, Мисливцю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]sad.2"
msgid "Come on, we'll head back to camp and get you patched up."
msgstr "Ходімо, повернемося в табір і підлатаємо вас."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[bonejaw,in_bossbattle,lost]skeptical.1"
msgid "You really don't want to be on the receiving end of his charge!"
msgstr "Вам точно не варто опинятися на шляху його тарану!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]confused.1"
msgid "Huh. Who knew the {name_multiple.cabbageroll} had a monarchy?"
msgstr "Хм. Хто б міг подумати, що в {2:{Name_multiple.cabbageroll}} є монархія?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]confused.2"
msgid "Do you think there's a {name.cabbageroll} parliament, too?"
msgstr "А ви думаєте, у {2:{Name.cabbageroll}} ще й парламент є?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]frustrated.1"
msgid "What a royal pain in the rump!"
msgstr "От уже й справді королівський клопіт!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]frustrated.2"
msgid "Down with the King!"
msgstr "Геть короля!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]frustrated.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]frustrated.3"
msgid "That {name.cabbageroll_miniboss} needs to be overthrown!"
msgstr "Того {2:{Name.cabbageroll_miniboss} треба скинути з трону!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]motivational.1"
msgid "Don't worry, next time you'll give him some royal payback!"
msgstr "Не переймайтеся, наступного разу ви влаштуєте йому королівську відплату!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]nervous.1"
msgid "That {name.cabbageroll_miniboss} sure likes to throw his weight around, huh?"
msgstr "Той {name.cabbageroll_miniboss} любить показати свою вагу, еге ж?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]sad.1"
msgid "<i>(sniffle)</> H-has someone been chopping onions...?"
msgstr "<i>(шморгає)</> Х-хтось тут ріже цибулю...?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[cabbageroll,in_bossbattle,lost]skeptical.1"
msgid "Timing your dodges for just before he lands will be key here..."
msgstr "Вчасно ухилятися, перед самим його ударом – ось що буде ключем..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]frustrated.1"
msgid "Well now, wasn't he a gem..."
msgstr "Ну хіба він не самоцвіт..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]motivational.1"
msgid "Smack frozen braziers a bit to relight them!"
msgstr "Вдарте по замороженій жаровні, щоб знову запалити її!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]motivational.2"
msgid "If you get frozen solid, make sure to wiggle!"
msgstr "Якщо замерзнете до крижаного стану, не забувайте рухатися!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]nervous.1"
msgid "Those teeth are so pretty, but so nasty..."
msgstr "Ці зуби такі красиві, але такі небезпечні..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]nervous.2"
msgid "Wow! That breath sure is chilly."
msgstr "Вау! Цей подих дійсно холодний."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]sad.1"
msgid "You looked so cold out there!"
msgstr "Ви виглядали таким холодним!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[crystroll,in_bossbattle,lost]skeptical.1"
msgid "Watch out. That thing's breath'll freeze straight through you."
msgstr "Обережно. Від його подиху вас проб'є крижаним холодом."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]confused.1"
msgid "I know it's wrong, but this whole thing has me really craving an omelette."
msgstr "Ох, знаю, це дивно, але вся ця ситуація змушує мене захотіти омлет."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]frustrated.1"
msgid "What a rotten egg!"
msgstr "От так яєчко!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]motivational.1"
msgid "Don't give up! You've almost cracked it!"
msgstr "Не здавайтесь! Ви майже розбили це!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]nervous.1"
msgid "Are you okay? You looked a bit scrambled out there."
msgstr "Ви в порядку? Виглядаєте трохи \"збитими\"."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]nervous.2"
msgid "That's one tough egg to crack..."
msgstr "Оце вже справді непросте яйце..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]nervous.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]nervous.3"
msgid "Oof. You really took a beating, huh?"
msgstr "Ой... Вам добряче дісталось, га?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]sad.1"
msgid "Don't worry Hunter, I've got you!"
msgstr "Не хвилюйтесь, Мисливцю, я вас тримаю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eggzy,in_end_boss,lost]skeptical.1"
msgid "Maybe there's a way to use its own strength against it..."
msgstr "Можливо, є спосіб використати його силу проти нього..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]frustrated.1"
msgid "That bull-headed brute!"
msgstr "Цей упертий бик!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]frustrated.2"
msgid "Hey, where's the referee?!"
msgstr "Гей, де суддя?!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]motivational.1"
msgid "Don't worry, Hunter! I know you'll get him next time!"
msgstr "Не хвилюйтесь, Мисливцю! Знаю, що ви здолаєте його наступного разу!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]motivational.2"
msgid "He might've won this round, but our fight isn't over!"
msgstr "Він виграв цей раунд, але наша битва ще не закінчена!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]nervous.1"
msgid "He's really got a mean right-hook, doesn't he?"
msgstr "У нього дійсно сильний хук правою, чи не так?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]sad.1"
msgid "Hunter! Are you okay?"
msgstr "Мисливець! Ви в порядку?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]sad.2"
msgid "Oooh... maybe we should put some ice on that."
msgstr "Ой... Може, варто прикласти сюди лід."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[embison,in_bossbattle,lost]skeptical.1"
msgid "Try baiting out his attacks before you strike, that'll make him lose his cool!"
msgstr "Спробуй виманити його на атаку перед ударом — це змусить його втратити контроль!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]confused.1"
msgid "Someone once told me to always 'go for the eyes'!"
msgstr "Хтось колись сказав мені: завжди бийте по очах!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]motivational.1"
msgid "Chin up, Hunter! It'll take more than that to keep the {name_multiple.foxtails} down for long!"
msgstr "Підніміть голову, Мисливцю! {Name_multiple.foxtails} так легко не приборкати!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]nervous.1"
msgid "Yikes. If looks could kill..."
msgstr "Ого. Якби погляд міг вбивати..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]nervous.2"
msgid "Talk about an evil eye..."
msgstr "Оце вже справжнє лихе око..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]nervous.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[eyev,in_bossbattle,lost]nervous.3"
msgid "Er... that was just a warm-up! Right?"
msgstr "Е-е... це ж була тільки розминка, правда?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]confused.1"
msgid "All that whirling and twirling... makes me dizzy!"
msgstr "Від усього цього крутіння та вертіння... у мене паморочиться голова!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]confused.2"
msgid "Did she <i>kick</i> you? That seems rude."
msgstr "Вона вас <i>пнула</i>? Здається, це неприємно."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]confused.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]confused.3"
msgid "I know you can beak her! I-I mean, beat her. Sorry."
msgstr "Я знаю, ви можете її побрити! Я-я маю на увазі, побити її. Вибачте."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]frustrated.1"
msgid "How dare that bird!"
msgstr "Як сміє ця пташка!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]nervous.1"
msgid "That beak looked pretty s-sharp!"
msgstr "Цей дзьоб виглядав досить гострим!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]nervous.2"
msgid "Hold on Hunter, I've got you!"
msgstr "Тримайтеся, Мисливцю, я вас тримаю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]skeptical.1"
msgid "This {name.floracrane} has nice footwork, I'll give her that."
msgstr "Цей {Name.floracrane} добре працює ногами, це треба визнати."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[floracrane,in_bossbattle,lost]skeptical.2"
msgid "You put up a good fight, Hunter."
msgstr "Ти добре бився, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]frustrated.1"
msgid "We lost this round, but we'll be back."
msgstr "Ми програли у цьому раунді, але головне, що ви в порядку."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]frustrated.2"
msgid "You nearly had it!"
msgstr "Ви майже це зробили!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]frustrated.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]frustrated.3"
msgid "Hey, you! Leave my Hunters alone!"
msgstr "Гей, ти! Залиш моїх Мисливців у спокої!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.1"
msgid "You almost won that Hunt!"
msgstr "Ви майже виграли те полювання!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.2"
msgid "That Boss better watch its back once you're feeling better!"
msgstr "Тому босу краще стежити за спиною, коли вам стане краще!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.3"
msgid "Let's head back and brainstorm new strategies."
msgstr "Давайте повернемося і придумаємо нову стратегію."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]motivational.4"
msgid "Live to fight another day, Hunter."
msgstr "Живи, щоб боротися ще один день, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]sad.1"
msgid "That didn't hurt, did it?"
msgstr "Це не боляче, правда?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]skeptical.1"
msgid "If you ask me, it's only a matter of time 'til you win."
msgstr "Якщо ви запитаєте мене, це лише питання часу, коли ви виграєте."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]skeptical.2"
msgid "Perhaps we need to take a different approach..."
msgstr "Можливо, нам потрібно застосувати інший підхід..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_end_boss,lost]skeptical.3"
msgid "You're sure to win now that we know its moves."
msgstr "Тепер ви точно виграєте, коли ми знаємо його рухи."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_mid_boss,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_mid_boss,lost]nervous.1"
msgid "That thing sure is nasty."
msgstr "Ця тварина справді неприємна."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_mid_boss,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[general,in_mid_boss,lost]sad.1"
msgid "Y-you'll get that thing next time!"
msgstr "Т-ти наступного разу впораєшся з тією тварюкою!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]confused.1"
msgid "Phew--it's going to take weeks to air that smell out of the {name.i_damselfly}..."
msgstr "Фух... Потрібно буде кілька тижнів, щоб вивітрити цей запах з {2:{Name.i_damselfly}}..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]confused.2"
msgid "He's surprisingly spry for his age, huh?"
msgstr "Він на диво прудкий для свого віку, еге ж?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]frustrated.1"
msgid "Ugh, this guy really stinks!"
msgstr "Уф, цей тип справді смердючий!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]frustrated.2"
msgid "That mean old coot!"
msgstr "Який злющий старий дідуган!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]motivational.1"
msgid "Whew--looks like I grabbed you just in time!"
msgstr "Уф... здається, я встиг вас вчасно схопити!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]motivational.2"
msgid "We'll be back to fight another day!"
msgstr "Ми ще повернемося, щоб битися знову!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]nervous.1"
msgid "Cut it a little close there--are you okay, Hunter?"
msgstr "Було трохи небезпечно... ви в порядку, Мисливцю?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]sad.1"
msgid "Ooooh... that's gonna leave a bruise..."
msgstr "Оооох... буде добрячий синець..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gnarlic,in_bossbattle,lost]skeptical.1"
msgid "He's got a strong charge attack, but it tires him out... that's the time to strike!"
msgstr "У нього потужна атака ривком, але вона його виснажує... тоді й треба бити!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]frustrated.1"
msgid "Hey! Who taught {name_multiple.gourdo} to team up?"
msgstr "Гей! Хто навчив тих {Name_multiple.gourdo} командній роботі?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]motivational.1"
msgid "Joke's on them! You'll just keep coming back, and they've got no way to stop you."
msgstr "Жарти в бік! Ви будете повертатися знову і знову, і вони не зможуть вас зупинити."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]nervous.1"
msgid "Holy guacamole! Are you okay??"
msgstr "Святе гуакамоле! З вами все гаразд??"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.1"
msgid "If you see them drop a healing seed, make sure to knock it out!"
msgstr "Якщо ви побачите, що вони впустили цілюще насіння, обов'язково знешкодьте його!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.2"
msgid "Did you see that? They always butt slam three times in a row."
msgstr "Ви це бачили? Вони завжди б'ють задом три рази поспіль."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.3"
msgid "You'll get those creeps next time, I know it."
msgstr "Наступного разу ви впораєтеся з тими дурнями, я впевнений."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[gourdo,in_bossbattle,lost]skeptical.4"
msgid "And here I thought veggies were supposed to be good for you."
msgstr "І тут я подумав, що овочі повинні бути корисними для вас."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]confused.1"
msgid "That carving on its trunk... it can't be the tree from my old backyard, can it?!"
msgstr "Ця позначка на стовбурі... це ж не може бути дерево з мого старого подвір'я, чи не так?!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]frustrated.1"
msgid "You know, I'm starting to really hate trees!"
msgstr "Знаєте, я починаю реально ненавидіти дерева!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]motivational.1"
msgid "You can do this, Hunter! For the Rotwood!"
msgstr "Ви зможете, Мисливцю! За Ротвуд!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]nervous.1"
msgid "At least we can leave for a bit... this place gives me the creeps."
msgstr "Принаймні ми можемо піти звідси на якийсь час... це місце мене лякає."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]nervous.2"
msgid "Let's get out of here!"
msgstr "Забираймося звідси!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]sad.1"
msgid "It'll be okay Hunter, stay with me!"
msgstr "Все буде добре, Мисливцю, тримайтеся!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]sad.2"
msgid "That looked like it really hurt..."
msgstr "Це виглядало справді боляче..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]sad.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]sad.3"
msgid "I really wish we didn't have to come back..."
msgstr "Хотілося б більше ніколи сюди не повертатися..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,in_end_boss,lost]skeptical.1"
msgid "Keep an eye out for its roots, they'll sneak up on you."
msgstr "Слідкуйте за корінням – вони можуть підкрастися непомітно."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,won]NOT[pf_met_npc_refiner,wf_town_has_refiner]confusedhuntprogress_found_lottie.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[grimhollow,won]NOT[pf_met_npc_refiner,wf_town_has_refiner]confusedhuntprogress_found_lottie.1"
msgid "Th-that's not Grandpa! Who is <i>she?</>"
msgstr "Ц-це не Дідусь! Хто <i>вона?</>"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.1"
msgid "T-that thing was disgusting!"
msgstr "Ц-це було огидно!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.2"
msgid "Yeesh. That guy makes my hackles stand on end."
msgstr "Жааах. Цей тип змушує мої волосини на шкірі стояти дибом."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.3"
msgid "I think you can dodge through the shockwave from his fist slams.\n"
"S-sorry if that was obvious."
msgstr "Мені здається, що ви можете ухилятися від ударних хвиль його кулаків.\n"
"В-вибачте, якщо це було очевидним."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.4"
msgid "I always feel like I need a bath after flying over this bog."
msgstr "Я завжди відчуваю, що мені потрібна ванна після польоту над цим болотом."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.5
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.5"
msgid "Let's go home, rest up, then give it another try."
msgstr "Підемо додому, відпочиньмо, а потім спробуємо ще раз."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.6
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]nervous.6"
msgid "Don't worry. Even the best Hunters take their lumps."
msgstr "Не хвилюйтесь. Навіть найкращі Мисливці іноді потрапляють під удари."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]sad.1"
msgid "At least now we can go home and get away from that smell."
msgstr "Принаймні тепер ми можемо піти додому і втекти від цього запаху."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]sad.2"
msgid "Hunter, you gotta kill that thing.\n"
"My peace of mind depends on it."
msgstr "Мисливцю, вам треба вбити цю тварину.\n"
"Мій душевний спокій залежить від цього."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[groak,in_bossbattle,lost]skeptical.1"
msgid "I know you can do it, Hunter. Don't let that guy win!"
msgstr "Ви зможете це, Мисливцю! Не дозвольте йому перемогти!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]confused.1"
msgid "I guess {name_multiple.mothball} don't practice gentle parenting."
msgstr "Схоже, {Name_multiple.mothball} не практикують лагідного батьківства."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]motivational.1"
msgid "Rest easy, Hunter. We can always give it another shot!"
msgstr "Відпочиньте, Мисливцю. Ми завжди можемо спробувати ще раз!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]sad.1"
msgid "Oof... that looked like it hurt..."
msgstr "Уф... це виглядало боляче..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,mothball_teen]sad.2"
msgid "Never underestimate a mother's love... for carnage."
msgstr "Ніколи не недооцінюйте материнську любов... до різанини."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]frustrated.1"
msgid "That thing is just <i>foul!</>"
msgstr "Ця потвора просто <i>огидна!</>"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]motivational.1"
msgid "You fought bravely, Hunter!"
msgstr "Ви билися хоробро, Мисливцю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]motivational.2"
msgid "Don't worry, we'll be back for some payback!"
msgstr "Не хвилюйтеся, ми ще повернемося по відплату!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,swarmy]nervous.1"
msgid "My poor seat cushions... I sure hope that goo washes out..."
msgstr "Мої бідні подушки... сподіваюся, ця гидота відмиється..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]frustrated.1"
msgid "Next time, let's squash that squash!"
msgstr "Наступного разу давайте розтопчимо цю гарбузину!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]motivational.1"
msgid "Don't be discouraged... I know you can win!"
msgstr "Не впадайте у відчай... Я знаю, ви можете перемогти!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]motivational.2"
msgid "Don't give up!"
msgstr "Не здавайся!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]nervous.1"
msgid "That {name.yammo}'s club s-sure looks spiky."
msgstr "Булава того {Name.yammo} виглядає с-справді шипастою."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]nervous.2"
msgid "Let's go get you fixed up."
msgstr "Нуж бо ходімо, треба вас вилікувати."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]skeptical.1"
msgid "There's an opening for some free hits while his club is stuck in the dirt."
msgstr "Є можливість завдати йому декілька безпечних ударів, коли його булава застрягає в землі."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,yammo]skeptical.2"
msgid "It looks like that {name.yammo}'s attacks have a blind spot.\n"
"He can't hit you while you're behind him."
msgstr "Здається, в атаках того {Name.yammo} є \"сліпа пляма\".\n"
"Він не може вас вдарити, коли ви знаходитесь позаду нього."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]confused.1"
msgid "What has that thing been eating?!"
msgstr "Чого він такого наївся?!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]motivational.1"
msgid "Oooh... that looked like it stung..."
msgstr "Оооох... виглядало, ніби боляче..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]motivational.2"
msgid "You'll get him next time, Hunter!"
msgstr "Наступного разу ви з ним точно впораєтесь, Мисливцю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]nervous.1"
msgid "Oooh... that looked like it stung..."
msgstr "Оооох... виглядало, ніби боляче..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_bossbattle,lost,zucco]nervous.2"
msgid "Looks like our Hunt's ending a little sooner than we hoped..."
msgstr "Схоже, наше полювання закінчується трохи раніше, ніж ми сподівалися..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]confused.1"
msgid "H-Hunter? You okay? Do you know where you are?"
msgstr "М-Мисливцю? Ви в порядку? Ви знаєте, де ви?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]frustrated.1"
msgid "Can't they just leave you alone!"
msgstr "Хіба вони не можуть просто залишити вас у спокої!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]motivational.1"
msgid "Don't worry Hunter, I've got you."
msgstr "Не хвилюйтесь, Мисливцю, я вас тримаю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]motivational.2"
msgid "I'll get you back home, Hunter."
msgstr "Я привезу вас додому, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]motivational.3"
msgid "Ready for a little {name.i_damselfly} ride?"
msgstr "Готові до невеличкої поїздки на {Name.i_damselfly}і?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.1"
msgid "Let's get you outta here!"
msgstr "Витягнімо вас звідси!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.2"
msgid "Phew! I'm rescuing you just in the nick of time!"
msgstr "Уф! Я врятував вас, якраз в останній момент!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.3"
msgid "Hold on, I'll pull you up!"
msgstr "Тримайтесь, я вас підійму!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.4"
msgid "Hey, Hunter? Oh, you're unconscious. Sorry!"
msgstr "Ей, Мисливцю? Ох, ви непритомні. Вибачте!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.5
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]nervous.5"
msgid "Hang on, Hunter!"
msgstr "Тримайтесь, Мисливцю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_early_hunt,lost]sad.1"
msgid "Hunter? <i>HUNTERRRR!</i>"
msgstr "Мисливцю? <i>МИСЛИВЦЮЮЮ!</i>"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]frustrated.1"
msgid "First she slaps my {name.i_damselfly}, and now this?!"
msgstr "Спочатку вона вдарила мій {Name.i_damselfly} а тепер це?!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]motivational.1"
msgid "Heyyy, you really whittled her down!"
msgstr "Гей, ви справді її принизили!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]motivational.2"
msgid "Don't worry, Hunter. You'll have plenty more chances."
msgstr "Все гаразд, Мисливцю. У вас буде ще багато шансів."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]motivational.3"
msgid "Don't give up!"
msgstr "Не здавайся!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]nervous.1"
msgid "Let's make like a tree and get the heck outta here!"
msgstr "Зробімо як це дерево і заберемося геть!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]nervous.2"
msgid "Hold on Hunter, I'm getting you out of there!"
msgstr "Тримайтесь, Мисливцю, я витягую вас звідти!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]sad.1"
msgid "You nearly had her!"
msgstr "Ви майже її дістали!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.1"
msgid "You put up a good fight, Hunter."
msgstr "Ти добре бився, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.2"
msgid "I'm starting to not like trees very much."
msgstr "Я починаю ненавидіти дерева."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.3"
msgid "Rest well Hunter, you did good getting this far."
msgstr "Гарно відпочиньте, Мисливцю, ви добре пройшли цей шлях."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.4"
msgid "It's okay to focus on dodging her root patterns.\n"
"Only strike when you feel confident."
msgstr "Це нормально, зосередитися на ухиленні від атак корінням.\n"
"Бийте лише тоді, коли відчуваєте впевненість."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.5
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,megatreemon]skeptical.5"
msgid "If you knock out those mines early, they won't surprise you later."
msgstr "Якщо ви одразу знешкодите ці міни, вони не здивують вас пізніше."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]frustrated.1"
msgid "Shoot! You were so close!"
msgstr "Стріляй! Ви були так близько!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]frustrated.2"
msgid "Grr... couldn't it just let you win??"
msgstr "Грр... чому вона не дає тобі перемогти??"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]frustrated.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]frustrated.3"
msgid "No fair! You were so close!"
msgstr "Нечесно! Ви були так близько!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]motivational.1"
msgid "Hang on! {name.npc_scout} to the rescue!"
msgstr "Руки вгору! {Name.npc_scout} летить на допомогу!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]nervous.1"
msgid "Yeesh, talk about birds of prey!"
msgstr "Ну, поговоримо про хижих птахів!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]sad.1"
msgid "Why does an owl need teeth??"
msgstr "Навіщо сові зуби??"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]sad.2"
msgid "I nearly jumped outta my pelt when it flew up here!"
msgstr "Я мало не вискочив зі своєї шкури, коли вона залетіла сюди!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]skeptical.1"
msgid "Hm... Looks like it puts eyes on whoever it's about to divebomb."
msgstr "Гм... Здається, вона наводить погляд на того, кого збирається атакувати."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]skeptical.2"
msgid "Keep your head on a swivel, Hunter.\n"
"Err, so to speak."
msgstr "Тримайте голову на поворотах, Мисливцю.\n"
"Eем, так би мовити."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,owlitzer]skeptical.3"
msgid "You didn't go down easy! Good work, Hunter."
msgstr "Ви не здались без бою! Гарна робота, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]frustrated.1"
msgid "Grr... what a boulderhead!"
msgstr "Бррр... що за валуноподібна голова!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]frustrated.2"
msgid "Oh, pebbles!"
msgstr "Ох, камінці!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]motivational.1"
msgid "Smack frozen braziers a couple times to relight them!"
msgstr "Вдарте по замороженій жаровні декілька разів, щоб знову запалити її!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]motivational.2"
msgid "We're coming back and grinding you down, mister!"
msgstr "Ми повернемось і перемелемо вас, містере!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]nervous.1"
msgid "Those icicles sure look sharp."
msgstr "Ці бурульки точно виглядають гострими."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]skeptical.1"
msgid "What's with that crow, anyway?"
msgstr "Що це за ворона?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]skeptical.2"
msgid "That's a pretty crystal it's got."
msgstr "Гарний у нього кристал."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,sedament]skeptical.3"
msgid "He's strong, but he moves slow. I know you can win."
msgstr "Він сильний, але рухається повільно. Я знаю, що ви можете перемогти."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]confused.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]confused.1"
msgid "H-How can it move that fast?"
msgstr "Я-як воно може рухатися так швидко?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]confused.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]confused.2"
msgid "I-I thought there'd be some piece of Grandpa still in there...\n"
"Could I have been wrong?"
msgstr "Я... я думав, що там залишилася хоч якась частинка Дідуся...\n"
" Невже я помилявся?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]confused.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]confused.3"
msgid "Primeval Teffra's power shouldn't even be <i>theoretically</> possible!"
msgstr "Сила Первісного Конжуру навіть <i>теоретично</> не повинна бути можливою!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]frustrated.1"
msgid "Dang it! It just won't let up!"
msgstr "Чорт! Воно просто не зупиняється!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]frustrated.2"
msgid "This Primeval Teffra being is relentless!"
msgstr "Це створіння Первісного Конжуру невпинне!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]frustrated.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]frustrated.3"
msgid "It's not holding back, Hunter. You can't either!\n"
"Even for my Grandpa's sake..."
msgstr "Воно не стримується, Мисливцю. І ви теж не можете!\n"
"Навіть заради мого Дідуся..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]motivational.1"
msgid "Let's get out of here! There's time yet to recoup and then stop the Second Eruption."
msgstr "Забираймося звідси! Ще є час оговтатися, а тоді зупинити Друге Виверження."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]motivational.2"
msgid "Stay with me, Hunter! We've seen his moves. We'll beat him yet."
msgstr "Тримайтеся, Мисливцю! Ми вже бачили його прийоми. Ми ще переможемо."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]motivational.3"
msgid "Whatever's got a hold of Grandpa, we'll send it packing. I just know it."
msgstr "Що б не захопило мого Дідуся, ми це проженемо. Я впевнений."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]nervous.1"
msgid "Careful, Hunter! We can't risk losing you to him, er--it. Whatever it is."
msgstr "Обережно, Мисливцю! Ми не можемо ризикувати втратити вас через нього... е-е... це. Що б це не було."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]nervous.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]nervous.2"
msgid "THAT'S Primeval Teffra?? I-it's terrifying..."
msgstr "ЦЕ і є Первісний Конжур?? В-воно жахає..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]nervous.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]nervous.3"
msgid "Got you--barely! If it wins, it's the end of everything..."
msgstr "Ухопив вас... ледве! Якщо воно переможе, це буде кінець усьому..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]sad.1"
msgid "I know that's not my Grandpa in there...\n"
"It <i>can't</> be."
msgstr "Я знаю, що це не мій Дідусь...\n"
"Це <i>не може</> бути він."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]sad.2"
msgid "I-I'm sure he wouldn't kill you... All the same, I'm glad I got you out of there."
msgstr "Я... я впевнений, що він би не вбив вас... У будь-якому разі, я радий, що витягнув вас звідти."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]sad.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]sad.3"
msgid "It's so hard to see him like that--taken over by that... that <i>THING.</>"
msgstr "Так важко бачити його таким... захопленим тією... тією <i>РІЧЧЮ.</>"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]skeptical.1"
msgid "I can't believe the Source of Teffra is alive--and that it's so mean!"
msgstr "Не можу повірити, що джерело конжуру живе — і що воно таке зле!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]skeptical.2"
msgid "The Source of Teffra should be more powerful. Could Grandpa be holding it back, somehow...?"
msgstr "Джерело конжуру мало б бути сильнішим. Може, Дідусь якось його стримує...?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,tefframech]skeptical.3"
msgid "I think our 'impurities' weakened the Primeval Teffra... I think we can beat it!"
msgstr "Думаю, наші 'домішки' послабили Первісний Конжур... Думаю, ми можемо його перемогти!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]motivational.1"
msgid "So <i>that's</i> where that music was coming from!"
msgstr "Ось <i>звідки</i> йшла музика!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]nervous.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]nervous.1"
msgid "Gross... where'd it get that bug leg?"
msgstr "Фее... звідки він взяв цю лапку жука?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]skeptical.1"
msgid "Oh... so that's why they call it \"shredding\"."
msgstr "Ох... ось чому його називають \"знищувачем\"."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[in_end_boss,lost,thatcher]skeptical.2"
msgid "Was that thing... trying to talk to you?"
msgstr "Ця істота... намагалася з вами поговорити?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]frustrated.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]frustrated.1"
msgid "Darn it! How has Grandpa made them so tough?"
msgstr "Чорт! Як Дідусь зробив їх такими міцними?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]frustrated.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]frustrated.2"
msgid "Grandpa upgraded the Rot? He should be on our side..."
msgstr "Дідусь покращив гнильців? Він же мав бути на нашому боці..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]frustrated.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]frustrated.3"
msgid "These Rot-Bots are so strong!"
msgstr "Ці гнильботи такі сильні!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]sad.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]sad.1"
msgid "Hang on, Hunter! We'll be back at camp in no time!"
msgstr "Тримайтеся, Мисливцю! Ми вже скоро будемо в таборі!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]sad.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]sad.2"
msgid "I've got you! Don't quit on me now, Hunter!"
msgstr "Я вас тримаю! Не здавайтеся зараз, Мисливцю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]sad.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]sad.3"
msgid "We won't lose you, Hunter! Not like this!"
msgstr "Ми вас не втратимо, Мисливцю! Не так!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.1"
msgid "You might need a just bit more power... Let's go find some Heartstones!"
msgstr "Можливо, вам потрібно ще трохи сили... Ходімо пошукаємо кам'яні серця!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.2"
msgid "Did you see? More Rot that are part-machine like Grimhollow..."
msgstr "Бачили? Ще більше гнилі, частково машинної, як Зловісна порожнеча..."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[lost,tefframech]NOT[any_super_frenzy,in_end_boss]skeptical.3"
msgid "How did they beat you?? We need to get you more power!"
msgstr "Як вони змогли вас перемогти?? Нам треба зробити вас сильнішим!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[tefframech,won]skeptical.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[tefframech,won]skeptical.1"
msgid "You're a hero, Hunter! I just wish my Grandpa hadn't fled. Where did he go?"
msgstr "Ви герой, Мисливцю! Шкода лише, що мій Дідусь утік. Куди він подівся?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[tefframech,won]skeptical.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[tefframech,won]skeptical.2"
msgid "You saved us from the Second Eruption! But... <i>was</> my Grandpa too far gone?"
msgstr "Ви врятували нас від Другого Виверження! Але... <i>чи</> мій Дідусь уже був безповоротно втрачений?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[tefframech,won]skeptical.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[tefframech,won]skeptical.3"
msgid "Hunter! You saved the Rotwood! My Grandpa, though... didn't he want to be saved, too?"
msgstr "Мисливцю! Ви врятували Ротвуд! Але мій Дідусь... хіба він теж не хотів, щоб його врятували?"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.1
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.1"
msgid "I knew you could do it, Hunter!"
msgstr "Я знав, що ви зможете, Мисливцю!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.2
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.2"
msgid "I love a successful Hunt!"
msgstr "Обожнюю успішне полювання!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.3
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.3"
msgid "A fine day's work, Hunter."
msgstr "Гарного дня, Мисливцю."

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.4
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.4"
msgid "Another step closer to taking back the Rotwood!"
msgstr "На ще один крок ближче до відновлення контролю над Ротвудом!"

#: Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.5
msgctxt "Quip.dgn_huntprogress_quips.QUIP.huntprogressscreen:[won]motivational.5"
msgid "Mark another win for the {name_multiple.foxtails}."
msgstr "{Name_multiple.foxtails} можуть занести ще одну перемогу."

#: STRINGS.ASCENSIONS.ADD_ELITES
msgctxt "STRINGS.ASCENSIONS.ADD_ELITES"
msgid "<p img='images/map_ftf/frenzy_2.tex' color=0> {name.elite_prefix} enemies spawn"
msgstr "<p img='images/map_ftf/frenzy_2.tex' color=0> З'являються {name.elite_prefix} вороги"

#: STRINGS.ASCENSIONS.AGGRESSIVE_BOSSES
msgctxt "STRINGS.ASCENSIONS.AGGRESSIVE_BOSSES"
msgid "<p img='images/map_ftf/frenzy_9.tex' color=0> {name_multiple.rot_boss} are more aggressive"
msgstr "<p img='images/map_ftf/frenzy_9.tex' color=0> {name_multiple.rot_boss} більш агресивні"

#: STRINGS.ASCENSIONS.AGGRESSIVE_ELITES
msgctxt "STRINGS.ASCENSIONS.AGGRESSIVE_ELITES"
msgid "<p img='images/map_ftf/frenzy_8.tex' color=0> {name.elite_prefix} enemies are more aggressive"
msgstr "<p img='images/map_ftf/frenzy_8.tex' color=0> {name.elite_prefix} вороги більш агресивні"

#: STRINGS.ASCENSIONS.AGGRESSIVE_ENEMIES
msgctxt "STRINGS.ASCENSIONS.AGGRESSIVE_ENEMIES"
msgid "<p img='images/map_ftf/frenzy_3.tex' color=0> Enemies are more aggressive"
